{
  "name": "oryxa",
  "private": true,
  "packageManager": "bun@1.2.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:api": "bun --filter api dev",
    "dev:web": "bun --filter web dev",
    "build": "bun run --filter '*' build",
    "db:push": "bun --filter @repo/db db:push",
    "db:studio": "bun --filter @repo/db db:studio",
    "gen:api": "bun --filter web gen:api",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:neon": "vitest run tests/neon",
    "test:neon:crud": "vitest run tests/neon/crud.test.ts"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@langchain/core": "^0.3.37",
    "@neondatabase/serverless": "^0.10.4",
    "@vitest/coverage-v8": "^3.0.5",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.39.1",
    "hono": "^4.7.2",
    "postgres": "^3.4.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
