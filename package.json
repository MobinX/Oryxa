{
  "name": "oryxa",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --filter @repo/api dev",
    "dev:api:vercel": "vercel dev --cwd apps/api --local --listen 3001 --yes",
    "dev:api2": "bun --filter api2 dev",
    "dev:web": "bun --filter web dev",
    "build": "bun run build:api && bun run build:web",
    "build:api": "bun --filter @repo/api build",
    "build:api2": "bun --filter api2 build",
    "build:web": "bun --filter web build",
    "start:api": "bun --filter @repo/api start",
    "start:api2": "bun --filter api2 start",
    "start:web": "bun --filter web start",
    "db:push": "bun --filter @repo/db db:push",
    "db:studio": "bun --filter @repo/db db:studio",
    "gen:api": "bun --filter web gen:api",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:neon": "vitest run tests/neon",
    "test:neon:crud": "vitest run tests/neon/crud.test.ts"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@langchain/core": "^0.3.37",
    "@neondatabase/serverless": "^0.10.4",
    "@vitest/coverage-v8": "^3.0.5",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.39.1",
    "hono": "^4.7.2",
    "postgres": "^3.4.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "version": "dev"
}
