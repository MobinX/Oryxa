# Database (Neon Postgres recommended)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Firebase Admin (API token verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Web (Next.js public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Gemini
GEMINI_API_KEY=

# Meta / Facebook
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=oryxa-webhook-verify
META_REDIRECT_URI=http://localhost:3001/api/v1/auth/facebook/callback

# Internal agent runner (self-referential on Vercel)
INTERNAL_KEY=change-me-to-random-secret
AGENT_RUNNER_URL=http://localhost:3001

# UploadThing
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=

# API / Web URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Dev ports
API_PORT=3001
WEB_PORT=3000
